[Unit]
Description=Relay Proxy - AI Agent SSH Relay
After=network.target

[Service]
Type=simple
User=relay
WorkingDirectory=/opt/relay-proxy
ExecStart=/opt/relay-proxy/.venv/bin/python -m uvicorn src.main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5

# 环境变量（通过 systemd 环境文件管理，不写在 service 里）
EnvironmentFile=/opt/relay-proxy/.env

# 日志
StandardOutput=journal
StandardError=journal
SyslogIdentifier=relay-proxy

[Install]
WantedBy=multi-user.target